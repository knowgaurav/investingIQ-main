[run]
source = shared,activity_fetch_data,activity_cache_data,activity_llm_analysis,activity_ml_analysis,activity_aggregate
omit = 
    */tests/*
    */__pycache__/*
    */.venv/*
    */llm_analysis_service.py
    */llm_providers.py
    */llm_providers_v2.py
    */llm_provider_factory_v2.py
    */llm_tools.py
    */llm_utils.py
    */webpubsub_utils.py
    */db_utils.py
    */embedding_utils.py
    */scraper_utils.py
    */llm_analysis_schemas.py

[report]
fail_under = 80
show_missing = true
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
